{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(tree:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(uv run:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Skill(remote-training)",
      "Skill(push-pr)",
      "Bash(../internal/scripts/start.sh:*)",
      "Bash(nebius:*)",
      "Bash(curl:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q -- '--amend' && echo 'BLOCKED: Never amend commits, create new ones instead' >&2 && exit 1; exit 0",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
